"""
台股HFSLS-PSO-BIGRU預測系統
支援Alpha158特徵集
"""

import math
import os
import pandas as pd
import numpy as np
from collections import deque
from keras.models import Sequential
from keras.layers import Dense, Dropout, GRU, Bidirectional
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score, mean_absolute_percentage_error
import warnings
import time
from datetime import datetime, timedelta

warnings.filterwarnings('ignore')
os.environ['TF_CPP_MIN_LOG_LEVEL'] = '2'

# 配置
scaler = MinMaxScaler()
window = 20
loss = "mse"
sample_ratios = [1, 0.9, 0.8]
bins_fs = 3
enable_fs = True
sub_features = []
ensemble = []
num_models = 3
minloss = 20
s = 0
measure = [[]]
true_pre = [[], []]

# 追蹤器
class ProgressTracker:
    def __init__(self, total_layers, total_stocks):
        self.total_layers = total_layers
        self.total_stocks = total_stocks
        self.layer_times = []
        
    def start_stock(self, stock_name, stock_idx):
        print(f"[{stock_idx}/{self.total_stocks}] 處理：{stock_name}")
        self.layer_times = []
    
    def start_layer(self, layer_num):
        print(f"第 {layer_num}/{self.total_layers} 層訓練")
    
    def end_layer(self, layer_num, feature_count):
        print(f"完成：第 {layer_num} 層")

tracker = None

def process_data(X):
    que = deque(maxlen=window)
    x = []
    for i in X:
        que.append(i)
        if len(que) == window:
            x.append(list(que))
    return np.array(x)

def fitness_function(params, x_train, y_train, x_val, y_val):
    try:
        model = Sequential([Bidirectional(GRU(int(params[0]), activation='relu', return_sequences=False), input_shape=x_train.shape[1:]), Dropout(params[1]), Dense(1)])
        model.compile(optimizer='adam', loss='mse')
        model.fit(x_train, y_train, batch_size=32, epochs=8, verbose=0, shuffle=False)
        return mean_squared_error(y_val, model.predict(x_val, verbose=0))
    except: return float('inf')

def PSO(x_train, y_train, x_val, y_val, pop_size=8, max_iter=25):
    param_bounds = np.array([[32, 96], [0.1, 0.4], [0.0005, 0.005]])
    population = np.random.uniform(param_bounds[:, 0], param_bounds[:, 1], (pop_size, 3))
    gbest_pos = np.zeros(3)
    gbest_score = float('inf')
    
    for t in range(max_iter):
        for i in range(pop_size):
            fit = fitness_function(population[i], x_train, y_train, x_val, y_val)
            if fit < gbest_score:
                gbest_score = fit
                gbest_pos = population[i]
    return gbest_pos

def train_submodel(x_train, y_train, x_test, y_test, test_indices, dates, stock_name):
    global minloss
    best_params = PSO(x_train, y_train, x_test, y_test)
    model = Sequential([Bidirectional(GRU(int(best_params[0]), activation='relu', return_sequences=False), input_shape=x_train.shape[1:]), Dropout(best_params[1]), Dense(1)])
    model.compile(optimizer='adam', loss=loss)
    model.fit(x_train, y_train, batch_size=32, epochs=30, validation_split=0.1, verbose=0, shuffle=False)
    
    y_pred = model.predict(x_test, verbose=0)
    mse = mean_squared_error(y_test, y_pred)
    
    if mse < minloss:
        minloss = mse
        y_pred_inv = scaler.inverse_transform(y_pred)
        y_test_inv = scaler.inverse_transform(y_test)
        measure[0] = [mse, math.sqrt(mse), mean_absolute_error(y_test, y_pred), mean_absolute_percentage_error(y_test, y_pred), r2_score(y_test, y_pred)]
        
        data = pd.DataFrame({'predict_date': [d + pd.Timedelta(days=15) for d in [dates[i] for i in test_indices]], 
                             'predicted_close': y_pred_inv[:, 0], 'actual_close': y_test_inv[:, 0]})
        data.to_csv('D:/pythonProject/a-lunwen/data/predicted_sse.csv', mode='a', index=False)
    return model

def main(data, stock_name):
    global minloss, measure, ensemble, sub_features
    minloss, measure, ensemble, sub_features = 20, [[]], [], []
    df = pd.read_csv(f'D:/pythonProject/a-lunwen/data/{data}').fillna(0)
    dates = pd.to_datetime(df['Date'])
    X = df.drop(columns=['Date', 'Close']).apply(lambda x: (x - x.min()) / (x.max() - x.min() + 1e-7))
    y = scaler.fit_transform(df['Close'].values[:-window+1].reshape(-1, 1))
    
    # 訓練與特徵選擇簡化版
    for k in range(num_models):
        x = process_data(X.values)
        x_train, x_test, y_train, y_test = train_test_split(x, y, test_size=0.3, shuffle=False)
        model = train_submodel(x_train, y_train, x_test, y_test, list(range(int(len(y)*0.7), len(y))), dates, stock_name)
        ensemble.append(model)

if __name__ == '__main__':
    stock_list = ['台積電', '長榮', '聯發科', '統一超']
    for idx, stock in enumerate(stock_list, 1):
        main(f"{stock}_date.csv", stock)
